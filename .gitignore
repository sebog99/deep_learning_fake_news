# --- Data (keep folders via .gitkeep, ignore the actual datasets) ---
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# --- Trained models / checkpoints (regenerated by running the notebook) ---
models/*
!models/.gitkeep

# --- Generated figures (optional; comment out if you want them tracked for the deck) ---
reports/figures/*
!reports/figures/.gitkeep

# --- Python / Jupyter ---
__pycache__/
*.py[cod]
.ipynb_checkpoints/
.virtual_documents/

# --- Environments ---
.venv/
venv/
env/

# --- OS / editor cruft ---
.DS_Store
Thumbs.db
.vscode/
.idea/
